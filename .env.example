# 复制为 .env 后修改。docker compose 会读取本目录下的 .env 做变量替换。
# 若 Postgres 数据卷已存在，仅改此处密码不会自动更新库内用户，需在库内执行：
# ALTER USER postgres WITH PASSWORD 'OfferDog2026'; 或 docker compose down -v 后重建（会清空数据）。
# 项目名称（卷名、网络名前缀）
# 对外可称 OfferDog；此处须小写（Docker Compose 限制）
COMPOSE_PROJECT_NAME=offerdog

# ---------- DeepSeek（对话、开场白、简历/题目结构化解析；OpenAI 兼容 https://api.deepseek.com ）----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat
# 简历解析等长请求可调大（毫秒，默认 600000=10 分钟）
# DEEPSEEK_READ_TIMEOUT_MS=600000
# 启动时自动导入 classpath knowledge-base（需嵌入模型可用；默认 false，建议首次用 POST /admin/knowledge-base/import）
# KB_IMPORT_ON_STARTUP=false
# 启动时写入「OfferDog 示例题库」12 道题并向量化（需嵌入可用、库中已有至少 1 个用户与二级岗位；默认 false）
INTERVIEW_SEED_SAMPLE_QUESTIONS=true
# ---------- 语音播报（豆包 TTS，非 DeepSeek；默认关闭）----------
# TTS_ENABLED=true
# DOUBAO_ENABLED=true
# DOUBAO_APP_ID=...
# DOUBAO_ACCESS_TOKEN=...
# ---------- 嵌入向量（Docker app 默认走硅基流动；复制为 .env 后必填）----------
# 创建嵌入：https://docs.siliconflow.cn/cn/api-reference/embeddings/create-embeddings
# Header: Authorization: Bearer <SILICONFLOW_API_KEY>；Body JSON: model, input, 可选 encoding_format(float|base64)、dimensions(Qwen3 系列)
# 各模型最大 input token 见文档（如 bge-large-zh 512、bge-m3 8192、Qwen3-Embedding 32768）
# 项目「全局」密钥：复制本文件为 .env 后填写（勿提交）。docker-compose / run-local.ps1 均会读取 SILICONFLOW_API_KEY；
# 本机 run-local.ps1 会同步注入 SPRING_AI_OPENAI_API_KEY，与 Spring AI 嵌入客户端一致。
SILICONFLOW_API_KEY=sk-your-siliconflow-key
# 以下为可选覆盖（镜像/compose 已默认硅基流动地址与 BAAI/bge-large-zh-v1.5）
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn
# SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# SILICONFLOW_EMBEDDING_ENCODING_FORMAT=float
# 使用 Qwen3-Embedding 并指定维数时：设 SILICONFLOW_EMBEDDING_DIMENSIONS=1024 且同步 PGVECTOR_DIMENSIONS（需与库表维数一致）
# SPRING_AI_OPENAI_EMBEDDING_OPTIONS_DIMENSIONS=1024
SPRING_PROFILES_ACTIVE=prod
# 带 Cookie 的跨域：逗号分隔 Origin 模式，勿用 *。代码默认已含 http://localhost:*、https://*.trycloudflare.com；生产请收紧为自有域名
# CORS_ALLOWED_ORIGIN_PATTERNS=https://app.example.com,https://www.example.com
# 本机在 Windows 宿主机跑 Spring（非 Docker app）：避开 Hyper-V 常见保留端口段 8004-8103（否则 Tomcat 报端口占用）
# 与 OfferDog-frontend/vite.config.ts 默认 VITE_DEV_BACKEND_URL 一致
SERVER_PORT=9080
# 仅本机访问后端时：SERVER_ADDRESS=127.0.0.1（默认 0.0.0.0 允许手机/局域网连你的 IP:端口）
# SERVER_ADDRESS=127.0.0.1

# ---------- PostgreSQL（本项目主库，需 pgvector；勿换成 MySQL）----------
POSTGRES_IMAGE=pgvector/pgvector:0.8.0-pg16
POSTGRES_CONTAINER_NAME=OfferDog_postgres
POSTGRES_DB=interview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=OfferDog2026
# 宿主机映射端口。若本机已安装 PostgreSQL 占 5432，请改为 15432，并让 SPRING_DATASOURCE_URL 用同一端口
POSTGRES_PORT=15432
# 本机跑 JAR 时（run-local.ps1）示例：
# SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:15432/interview?serverTimezone=Asia/Shanghai&reWriteBatchedInserts=true

# ---------- Redis ----------
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=OfferDog_redis
REDIS_PASSWORD=OfferDog2026
# 映射到容器的宿主机端口（Compose 专用，避免与 REDIS_PORT 环境冲突）
REDIS_PUBLISH_PORT=16378
# 本机跑 JAR / 脚本连 Redis 时用此端口（须与 REDIS_PUBLISH_PORT 一致）
REDIS_PORT=16378

# ---------- MinIO ----------
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_CONTAINER_NAME=OfferDog_minio
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=PaiSmart2025
MINIO_BUCKET_NAME=interview
# API / 控制台宿主机端口；可与上一项目一样用 19000 / 19001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Whisper ASR ----------
# WHISPER_IMAGE：Docker 镜像（仓库:标签须小写），例如 offerdog-whisper:latest
# WHISPER_CONTAINER_NAME：docker ps 里看到的容器名（常见为 OfferDog_whisper）
WHISPER_IMAGE=offerdog-whisper:latest
WHISPER_CONTAINER_NAME=OfferDog_whisper
# 宿主机映射端口:容器内 5000。示例 5002:5000 时，本机浏览器/curl 用 http://127.0.0.1:5002；Spring 跑在 app 容器里仍用 WHISPER_ENDPOINT=http://whisper:5000（与宿主机端口无关）
WHISPER_PORT=5002
WHISPER_MODEL_SIZE=tiny

# ---------- Spring Boot 应用容器 ----------
APP_IMAGE=offerdog:latest
APP_CONTAINER_NAME=OfferDog_app
# 宿主机映射（避开 Windows 8004-8103 保留段）；本机 npm run dev 时设 VITE_DEV_BACKEND_URL=http://127.0.0.1:9081
APP_PORT=9081
ASR_PROVIDER=whisper
# 浏览器 ScriptProcessor 多为 48kHz；若 WS init 未传 sampleRate，Whisper 写 WAV 需与此一致（否则识别为空）
# ASR_WHISPER_DEFAULT_PCM_SAMPLE_RATE=48000
# ASR_WHISPER_LANGUAGE=auto
SPRING_SESSION_NAMESPACE=inai:session
# 宿主机运行 JAR 时与 MinIO 一致
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=PaiSmart2025
SPRING_DATASOURCE_PASSWORD=OfferDog2026
ELASTIC_PASSWORD=PaiSmart2025

# ---------- 本机在容器外运行 JAR 时（host.docker.internal）----------
# SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/interview?serverTimezone=Asia/Shanghai&reWriteBatchedInserts=true
# REDIS_HOST=host.docker.internal
# REDIS_PORT=6379
# MINIO_ENDPOINT=http://host.docker.internal:9000
# MINIO_URL_PREFIX=http://localhost:9000
# 仅当某容器要访问「宿主机上的」Whisper 时用宿主机映射端口，例如 http://host.docker.internal:5002

# ---------- 内网穿透（Cloudflare Quick Tunnel；需 Docker + 本机已跑前端）----------
# 1) 终端 A：cd OfferDog-frontend && npm run dev
# 2) 终端 B：.\tunnel-cloudflared.ps1 或 .\tunnel-cloudflared.ps1 -Detached
# 3) 手机浏览器打开日志里的 https://*.trycloudflare.com（与页面同源，含 /api /ws /public 头像代理）
# 默认 TUNNEL_TARGET=http://host.docker.internal:5173；仅 API：.\tunnel-cloudflared.ps1 -Preset api
# TUNNEL_TARGET=http://host.docker.internal:9081  （穿透 compose 内 app 映射口）
# CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
# CLOUDFLARED_CONTAINER_NAME=OfferDog_cloudflared

# ---------- 可选：docker compose --profile extended（本仓库 Java 未使用）----------
# KAFKA_IMAGE=bitnamilegacy/kafka:latest
# KAFKA_CONTAINER_NAME=OfferDog_kafka
# KAFKA_PORT=9092
# KAFKA_CONTROLLER_PORT=9093
#
# ES_IMAGE=elasticsearch:8.10.4
# ES_CONTAINER_NAME=OfferDog_elasticsearch
# ELASTIC_PASSWORD=PaiSmart2025
# ELASTICSEARCH_PORT=19200
# ES_JAVA_OPTS=-Xms512m -Xmx512m
# ES_MEM_LIMIT=2g
